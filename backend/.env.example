# Server
NODE_ENV=development
PORT=5001
CLIENT_ORIGIN=http://localhost:3000

# Database
MONGO_URI=mongodb://localhost:27017/adaptive-code-platform

# Auth
JWT_ACCESS_SECRET=changeme_generate_a_long_random_value
JWT_REFRESH_SECRET=changeme_generate_a_different_long_random_value
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# MFA
MFA_ISSUER=AdaptiveCodePlatform

# EXP ledger signing
EXP_LEDGER_HMAC_SECRET=changeme_generate_a_long_random_value

# AI summary (OpenRouter)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=

# Rate limiting
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=5

# Session/cookies
COOKIE_DOMAIN=localhost
